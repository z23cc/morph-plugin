{
  "name": "@morphllm/morph-plugin",
  "version": "3.0.0",
  "description": "Claude Code plugin for Morph SDK — Fast Apply, WarpGrep codebase search, GitHub repo context",
  "type": "module",
  "main": "dist/src/cli/index.js",
  "bin": {
    "morph": "./dist/src/cli/index.js"
  },
  "exports": {
    ".": "./dist/src/core/index.js"
  },
  "files": [
    "dist",
    ".claude-plugin",
    "skills",
    "hooks",
    "instructions",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "bun test",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "ci": "bun test && bun run build && bun run typecheck"
  },
  "dependencies": {
    "@morphllm/morphsdk": "^0.2.134"
  },
  "devDependencies": {
    "bun-types": "latest",
    "typescript": "^5.0.0"
  },
  "keywords": [
    "claude-code",
    "plugin",
    "morph",
    "fast-apply",
    "warpgrep",
    "code-search",
    "code-editing",
    "cli"
  ],
  "author": "Morph",
  "repository": {
    "type": "git",
    "url": "https://github.com/z23cc/morph-plugin.git"
  },
  "bugs": {
    "url": "https://github.com/z23cc/morph-plugin/issues"
  },
  "homepage": "https://github.com/z23cc/morph-plugin#readme",
  "license": "MIT"
}
